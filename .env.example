# Supabase environment variables — copy to .env and fill in your values.
# NEVER commit .env to version control.

# Found in: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Found in: Supabase Dashboard → Project Settings → API → anon public key
# This key is safe to expose in frontend code.
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── NEVER add these to frontend code ──────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY  ← server/edge functions only
# SUPABASE_DB_PASSWORD       ← migrations/CLI only
